<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Rename group "User: all timesheets" to "Leader" -->
        <record id="hr_timesheet.group_hr_timesheet_approver" model="res.groups">
            <field name="name">Leader</field>
        </record>

        <!-- Rename group "User: own timesheets only" to "Member" -->
        <record id="hr_timesheet.group_hr_timesheet_user" model="res.groups">
            <field name="name">Member</field>
        </record>

        <!-- Rename group "Administrator" to "Manager" -->
        <record id="hr_timesheet.group_timesheet_manager" model="res.groups">
            <field name="name">Manager</field>
        </record>

        <!-- Rename group project Admin to Manager-->
        <record id="project.group_project_manager" model="res.groups">
            <field name="name">Manager</field>
        </record>

        <!-- Rename group project User to Other ( Not Use) -->
        <record id="project.group_project_user" model="res.groups">
            <field name="name">Other</field>
        </record>

        <!-- Create new group project Member -->
        <record id="group_project_member" model="res.groups">
            <field name="name">Member</field>
            <field name="privilege_id" ref="project.res_groups_privilege_project"/>
            <!-- <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('hr_timesheet.group_hr_timesheet_user'))]"/> -->
        </record>

        <!-- Create new group project Leader -->
        <record id="group_project_leader" model="res.groups">
            <field name="name">Leader</field>
            <field name="privilege_id" ref="project.res_groups_privilege_project"/>
            <field name="implied_ids" eval="[(4, ref('project_wbs_extension.group_project_member'))]"/>
        </record>

        <!-- Hiện menu project cho 2 group Leader và Member -->
        <record id="project.menu_main_pm" model="ir.ui.menu">
            <field name="group_ids" eval="[
                (4, ref('project.group_project_manager')), 
                (4, ref('project_wbs_extension.group_project_leader')), 
                (4, ref('project_wbs_extension.group_project_member'))
            ]"/>
        </record>

        <!-- Hide menu project / reporting / task analysis -->
        <record id="project.menu_project_report_task_analysis" model="ir.ui.menu">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_no_one')])]"/>
        </record>

        <!-- Hide menu project / reporting / Customer Ratings -->
        <record id="project.rating_rating_menu_project" model="ir.ui.menu">
            <field name="group_ids" eval="[(6, 0, [ref('base.group_no_one')])]"/>
        </record>

        <!-- Hide menu timesheets reporting -->
        <record id="hr_timesheet.menu_timesheets_reports" model="ir.ui.menu">
            <field name="name">Reporting</field>
            <field name="group_ids" eval="[(6, 0, [ref('base.group_no_one')])]"/>
        </record>
        
    </data>

    <data noupdate="1">
        <record id="project.project_public_members_rule" model="ir.rule">
            <field name="active" eval="False"/>
        </record>

        <record id="project.task_visibility_rule" model="ir.rule">
            <field name="active" eval="False"/>
        </record>

        <record id="project.task_visibility_rule_project_user" model="ir.rule">
            <field name="active" eval="False"/>
        </record>

        <record id="project.ir_rule_private_task" model="ir.rule">
            <field name="active" eval="False"/>
        </record>

        <record id="hr_timesheet.timesheet_line_rule_user" model="ir.rule">
            <field name="active" eval="False"/>
        </record>

        <record id="project.project_project_manager_rule" model="ir.rule">
            <field name="active" eval="False"/>
        </record>

        <record id="project.project_manager_all_project_tasks_rule" model="ir.rule">
            <field name="active" eval="False"/>
        </record>

        <!-- Set permission for group Project Member: Only read project -->
        <record id="project_member_project_rule" model="ir.rule">
            <field name="name">Project: members can read assigned projects</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">[('member_ids', 'in', [user.id])]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_member'))]"/>
        </record>

        <!-- Set permission for group Project Leader: Read and write project -->
        <record id="project_leader_project_rule" model="ir.rule">
            <field name="name">Project: leaders can manage their projects</field>
            <field name="model_id" ref="project.model_project_project"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_leader'))]"/>
        </record>

        <!-- Set permission for group Project Member: Only read task -->
        <record id="project_member_task_rule" model="ir.rule">
            <field name="name">Project Task: members can read project tasks</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">[('project_id.member_ids', 'in', [user.id])]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_member'))]"/>
        </record>

        <!-- Set permission for group Project Leader: Read and write task -->
        <record id="project_leader_task_rule" model="ir.rule">
            <field name="name">Project Task: leaders can manage project tasks</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">[('project_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_leader'))]"/>
        </record>

        <!-- Set permission for group Project Manager: Full control task -->
        <record id="project_manager_task_rule" model="ir.rule">
            <field name="name">Project Task: Managers can manage project tasks</field>
            <field name="model_id" ref="project.model_project_task"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>

        <!-- Set permission for group Project Member: Only read WBS -->
        <record id="project_member_wbs_rule" model="ir.rule">
            <field name="name">Project WBS: members can read project WBS</field>
            <field name="model_id" ref="model_project_task_phase"/>
            <field name="domain_force">[('project_id.member_ids', 'in', [user.id])]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_member'))]"/>
        </record>

        <!-- Set permission for group Project Leader: Read and write task -->
        <record id="project_leader_wbs_rule" model="ir.rule">
            <field name="name">Project WBS: leaders can manage project WBS</field>
            <field name="model_id" ref="model_project_task_phase"/>
            <field name="domain_force">[('project_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_leader'))]"/>
        </record>

        <!-- Set permission for group Project Member: All permission timesheets -->
        <record id="project_member_timesheet_rule" model="ir.rule">
            <field name="name">Timesheet: members can manage their own timesheets</field>
            <field name="model_id" ref="analytic.model_account_analytic_line"/>
            <field name="domain_force">[('user_id', '=', user.id), ('project_id.member_ids', 'in', [user.id])]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_member'))]"/>
        </record>

        <!-- Set permission for group Project Member: All permission timesheets -->
        <record id="project_leader_timesheet_rule" model="ir.rule">
            <field name="name">Timesheet: leaders can manage timesheets on their projects</field>
            <field name="model_id" ref="analytic.model_account_analytic_line"/>
            <field name="domain_force">[('project_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_leader'))]"/>
        </record>
        <!-- Issues: Members can read all project issues -->
        <record id="project_member_issue_read_rule" model="ir.rule">
            <field name="name">Project Issue: members can read project issues</field>
            <field name="model_id" ref="model_project_issue"/>
            <field name="domain_force">[('project_id.member_ids', 'in', [user.id])]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_member'))]"/>
        </record>

        <!-- Issues: Creator can write their own issues -->
        <record id="project_member_issue_creator_rule" model="ir.rule">
            <field name="name">Project Issue: creator can manage their issues</field>
            <field name="model_id" ref="model_project_issue"/>
            <field name="domain_force">[('reported_by', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_member'))]"/>
        </record>

        <!-- Issues: Members can write their assigned issues (limited fields via Python) -->
        <record id="project_member_issue_assigned_rule" model="ir.rule">
            <field name="name">Project Issue: members can write assigned issues</field>
            <field name="model_id" ref="model_project_issue"/>
            <field name="domain_force">[('assigned_to', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_member'))]"/>
        </record>

        <!-- Issues: Leaders have full access to issues -->
        <record id="project_leader_issue_rule" model="ir.rule">
            <field name="name">Project Issue: leaders full access</field>
            <field name="model_id" ref="model_project_issue"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('project_wbs_extension.group_project_leader'))]"/>
        </record>

        <!-- Project Manager: Full access to issues -->
        <record id="project_manager_issue_rule" model="ir.rule">
            <field name="name">Project Issue: manager full access</field>
            <field name="model_id" ref="model_project_issue"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>
    </data>
</odoo>
