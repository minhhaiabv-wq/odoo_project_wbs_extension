<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- for page project edit  -->
    <record id="view_project_form_planning" model="ir.ui.view">
        <field name="name">project.project.form.members</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="is_project_manager" invisible="1"/>
                <field name="phase_ids" widget="many2many_tags" readonly="not is_project_manager"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='date_start']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='description']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='allow_recurring_tasks']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='allow_task_dependencies']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='allow_milestones']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='privacy_visibility']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='date']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_issues" type="object" class="oe_stat_button" icon="fa-bug">
                    <field name="issue_count" widget="statinfo" string="Issues"/>
                </button>
                <button name="action_view_reviews" type="object" class="oe_stat_button" icon="fa-check-square-o">
                    <field name="review_count" widget="statinfo" string="Reviews"/>
                </button>
            </xpath>
            <xpath expr="//sheet/group" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//notebook" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//div[hasclass('oe_title')]" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//sheet/group" position="after">
                <group col="2">
                    <group string="Members" colspan="2">
                        <field name="member_ids" nolabel="1" colspan="2" readonly="not is_project_manager">
                            <list>
                                <field name="name"/>
                                <field name="login"/>
                                <field name="login_date"/>
                            </list>
                        </field>
                    </group>
                </group>
            </xpath>
            <xpath expr="//group/group/field[@name='partner_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group/group/field[@name='label_tasks']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[@name='button_box']//field[@name='label_tasks']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group/group/field[@name='company_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group/group/field[@name='user_id']" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_manager_ids)]</attribute>
            </xpath>
        </field>
    </record>

    <!-- for page project type=list  -->
    <record id="view_project_tree_planning" model="ir.ui.view">
        <field name="name">project.project.list.planning</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">
            <!-- add progress in list -->
            <xpath expr="//list" position="inside">
                <field name="resolved_issue" string="Resolved/Issue" width="100px"/>
                <field name="progress" widget="project_task_progressbar" options="{'overflow_class': 'bg-danger'}" optional="hide"/>
            </xpath>
            <!-- add menu in popup -->
            <xpath expr="//button[@name='action_view_tasks']" position="after">
                <button string="View WBS" name="action_view_wbs" type="object"/>
                <button string="View Performance" name="action_view_wbs_report" type="object"/>
            </xpath>
        </field>
    </record>

    <!-- for page project type=kanban  -->
    <record id="view_project_kanban_inherit_wbs_menu" model="ir.ui.view">
        <field name="name">project.project.kanban.inherit.wbs</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="arch" type="xml">
            <!-- add link to content card -->
            <xpath expr="//field[@name='tag_ids']" position="after">
                <!-- show phase in card -->
                <div class="d-flex align-items-baseline">
                    <span class="fa fa-road me-2 text-muted" title="Phase"/>
                    <field name="phase_ids"/>
                </div>
                <!-- show WBS link in card -->
                <div class="d-flex align-items-baseline">
                    <span class="fa fa-table me-2 text-muted" title="View WBS"/>
                    <a name="action_view_wbs" type="object" title="View WBS"> View WBS</a>
                </div>
                <!-- show performance link in card -->
                <div class="d-flex align-items-baseline">
                    <span class="fa fa-bolt me-3 text-muted" title="View Performance"/>
                    <a name="action_view_wbs_report" type="object" title="View Performance"> View Performance</a>
                </div>
                <!-- show reviews link in card -->
                <div class="d-flex align-items-baseline">
                    <span class="fa fa-check-square-o me-2 text-muted" title="View Reviews"/>
                    <a name="action_view_reviews" type="object" title="View Reviews">
                        <field name="review_status"/>
                    </a>
                </div>
                <!-- show issues link in card -->
                <div class="d-flex align-items-baseline">
                    <span class="fa fa-bug me-2 text-muted" title="View Issues"/>
                    <a name="action_view_issues" type="object" title="View Issues">
                        <field name="resolved_issue"/>
                    </a>
                </div>
            </xpath>
        </field>
    </record>
</odoo>