<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_issue_tree" model="ir.ui.view">
        <field name="name">project.issue.tree</field>
        <field name="model">project.issue</field>
        <field name="arch" type="xml">
            <list string="Issues" class="issue-list" expand="true" decoration-warning="state == 'open'" decoration-info="state == 'resolved'" decoration-success="state == 'closed'">
                <field name="priority" widget="priority" nolabel="1"/>
                <field name="issue_no" string="No."/>
                <field name="name"/>
                <field name="task_id"/>
                <field name="phase_id"/>
                <field name="assigned_to"/>
                <field name="date_reported"/>
                <field name="date_resolved" optional="hide"/>
                <field name="state" widget="badge" decoration-warning="state == 'open'" decoration-info="state == 'resolved'" decoration-success="state == 'closed'" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_project_issue_form" model="ir.ui.view">
        <field name="name">project.issue.form</field>
        <field name="model">project.issue</field>
        <field name="arch" type="xml">
            <form string="Issue">
                <header>
                    <field name="can_change_state" invisible="1"/>
                    <field name="is_leader_or_manager" invisible="1"/>
                    <button name="action_confirm" string="Open" type="object" invisible="state != 'draft' or not can_change_state" class="oe_highlight"/>
                    <button name="action_resolve" string="Resolve" type="object" invisible="state != 'open' or not can_change_state" class="oe_highlight"/>
                    <button name="action_close" string="Close" type="object" invisible="state != 'resolved' or not can_change_state" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,resolved,closed" options="{'clickable': '1'}" invisible="not is_leader_or_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,resolved,closed" invisible="is_leader_or_manager"/>
                </header>
                <sheet>
                    <field name="is_creator" invisible="1"/>
                    <field name="is_assigned" invisible="1"/>
                    <div class="oe_button_box">
                        <div class="d-flex justify-content-between align-items-center">
                            <h1 class="w-100">
                                <div class="d-flex">
                                    <field name="issue_no" class="me-2" invisible="not issue_no"/>
                                    <span class="me-2" invisible="not issue_no">-</span>
                                    <field class="text-break" name="name" options="{'line_breaks': False}" widget="text" placeholder="Issue Title..." readonly="not is_leader_or_manager and not is_creator"/>
                                </div>
                            </h1>
                            <div class="d-flex justify-content-end align-items-center">
                                <field name="priority" class="h3 pe-2" widget="priority_switch"/>
                            </div>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" domain="[('is_template', '=', False)]" readonly="not is_leader_or_manager and not is_creator"/>
                            <field name="project_phase_ids" invisible="1"/>
                            <field name="task_id" domain="[('project_id', '=', project_id)]" readonly="not is_leader_or_manager and not is_creator"/>
                            <field name="phase_id" domain="[('id', 'in', project_phase_ids)]" readonly="not is_leader_or_manager and not is_creator"/>
                        </group>
                        <group>
                            <field name="project_member_ids" invisible="1"/>
                            <field name="reported_by" domain="[('id', 'in', project_member_ids)]" readonly="not is_leader_or_manager and not is_creator"/>
                            <field name="assigned_to" domain="[('id', 'in', project_member_ids)]" readonly="not is_leader_or_manager and not is_creator"/>
                            <field name="date_reported" readonly="not is_leader_or_manager and not is_creator"/>
                            <field name="date_resolved" readonly="not is_leader_or_manager and not is_creator and not is_assigned"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content">
                            <field name="content" placeholder="Write Issue content here..." readonly="not is_leader_or_manager and not is_creator and not is_assigned"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_project_issue_search" model="ir.ui.view">
        <field name="name">project.issue.search</field>
        <field name="model">project.issue</field>
        <field name="arch" type="xml">
            <search string="Search Issues">
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="phase_id"/>
                <field name="assigned_to"/>
                <filter string="My Reported" name="my_reported" domain="[('reported_by', '=', uid)]"/>
                <filter string="My Issues" name="my_issues" domain="[('assigned_to', '=', uid)]"/>
                <separator/>
                <filter string="High Priority" name="high_priority" domain="[('priority', 'in', ('2', '3'))]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Open" name="open" domain="[('state', '=', 'open')]"/>
                <filter string="Resolved" name="resolved" domain="[('state', '=', 'resolved')]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <group>
                    <filter string="Project" name="group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Task" name="group_by_task" context="{'group_by': 'task_id'}"/>
                    <filter string="Phase" name="group_by_phase" context="{'group_by': 'phase_id'}"/>
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Priority" name="group_by_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_project_issue" model="ir.actions.act_window">
        <field name="name">Issues</field>
        <field name="res_model">project.issue</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_project_issue_search"/>
        <field name="context">{'search_default_group_by_project': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record a new issue
            </p>
        </field>
    </record>

    <menuitem id="menu_project_issue"
              name="Issues"
              parent="project.menu_main_pm"
              action="action_project_issue"
              sequence="6"/>
</odoo>
