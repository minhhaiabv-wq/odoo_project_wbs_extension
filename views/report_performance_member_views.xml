<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_report_performance_member_list" model="ir.ui.view">
        <field name="name">member.performance.report.list</field>
        <field name="model">report.performance.member</field>
        <field name="arch" type="xml">
            <list string="Member performance" create="0" delete="0">
                <field name="project_id" />
                <field name="user_id" />
                <field name="planned_hours" sum="Sum planned hours"/>
                <field name="actual_hours" sum="Sum actual hours"/>
                <field name="performance_ratio" 
                    widget="badge"
                    decoration-success="performance_ratio &gt; 0 and performance_ratio &lt;= 0.6"
                    decoration-warning="performance_ratio &gt; 0.6 and performance_ratio &lt;= 1"
                    decoration-danger="performance_ratio &gt; 1"/>
            </list>
        </field>
    </record>

    <!-- Member Performance action-->
    <record id="action_member_performance_report" model="ir.actions.act_window">
        <field name="name">Member Performance</field>
        <field name="res_model">report.performance.member</field>
        <field name="view_mode">list</field>
        <field name="domain">[('project_id.active', '=', True)]</field>
        <field name="context">{'group_by': ['project_id', 'user_id'], 'search_default_group_by_project': 1, 'search_default_group_by_user': 1}</field>
        <field name="target">current</field>
        <field name="path">member-performance</field>
    </record>

    <!-- Add menu Member Performance to project -->
    <menuitem id="menu_report_performance_member" name="Member Performance"
            parent="project.menu_project_report"
            action="action_member_performance_report"
            sequence="2"/>

    <!-- <record id="action_member_performance_report_virtual" model="ir.actions.server">
        <field name="name">Member Performance Virtual</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">action = env['report.performance.member'].action_generate_report()</field>
    </record>
    <menuitem id="menu_report_performance_member_virtual" name="Member Performance Virtual"
            parent="project.menu_project_report"
            action="action_member_performance_report_virtual"
            sequence="3"/> -->
</odoo>
