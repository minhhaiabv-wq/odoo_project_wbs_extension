<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_review_tree" model="ir.ui.view">
        <field name="name">project.review.tree</field>
        <field name="model">project.review</field>
        <field name="arch" type="xml">
            <list string="Reviews">
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="phase_id"/>
                <field name="reviewer_id"/>
                <field name="assigned_to"/>
                <field name="date"/>
                <field name="state" widget="badge" decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_project_review_form" model="ir.ui.view">
        <field name="name">project.review.form</field>
        <field name="model">project.review</field>
        <field name="arch" type="xml">
            <form string="Review">
                <header>
                    <field name="can_change_state" invisible="1"/>
                    <field name="is_leader_or_manager" invisible="1"/>
                    <button name="action_done" string="Complete" type="object" invisible="state != 'draft' or not can_change_state" class="oe_highlight"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done" options="{'clickable': '1'}" invisible="not is_leader_or_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done" invisible="is_leader_or_manager"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Review Title"/>
                        <h1>
                            <field class="text-break" name="name" options="{'line_breaks': False}" widget="text" placeholder="Review Title..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" domain="[('is_template', '=', False)]"/>
                            <field name="project_phase_ids" invisible="1"/>
                            <field name="task_id" domain="[('project_id', '=', project_id)]"/>
                            <field name="phase_id" domain="[('id', 'in', project_phase_ids)]"/>
                        </group>
                        <group>
                            <field name="project_member_ids" invisible="1"/>
                            <field name="reviewer_id" domain="[('id', 'in', project_member_ids)]"/>
                            <field name="assigned_to" domain="[('id', 'in', project_member_ids)]"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content">
                            <field name="content" placeholder="Write Review Content..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_project_review_search" model="ir.ui.view">
        <field name="name">project.review.search</field>
        <field name="model">project.review</field>
        <field name="arch" type="xml">
            <search string="Search Reviews">
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="phase_id"/>
                <field name="reviewer_id"/>
                <field name="assigned_to"/>
                <filter string="My Reported" name="my_reported" domain="[('reviewer_id', '=', uid)]"/>
                <filter string="My Assigned" name="my_assigned" domain="[('assigned_to', '=', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <group>
                    <filter string="Project" name="group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Task" name="group_by_task" context="{'group_by': 'task_id'}"/>
                    <filter string="Phase" name="group_by_phase" context="{'group_by': 'phase_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_project_review" model="ir.actions.act_window">
        <field name="name">Reviews</field>
        <field name="res_model">project.review</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_project_review_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new review
            </p>
        </field>
    </record>

    <menuitem id="menu_project_review"
              name="Reviews"
              parent="project.menu_main_pm"
              action="action_project_review"
              sequence="5"/>
</odoo>
