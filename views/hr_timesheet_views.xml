<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_timesheet_line_tree_inherit_wbs" model="ir.ui.view">
        <field name="name">account.analytic.line.list.hr_timesheet.wbs</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_tree"/>
        <field name="arch" type="xml">
            <field name="task_id" position="after">
                <field name="phase_id"
                    string="Phase line"
                    optional="show"
                    options="{'no_create_edit': True, 'no_open': True}"
                    readonly="readonly_timesheet"/>
                <field name="progress" string="Progress %" optional="show"/>
                <field name="end_flag" widget="boolean_toggle"/>
            </field>
        </field>
    </record>

    <record id="hr_timesheet_line_form_inherit_wbs" model="ir.ui.view">
        <field name="name">account.analytic.line.form.hr_timesheet.wbs</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_form"/>
        <field name="arch" type="xml">
            <field name="task_id" position="after">
                <field name="phase_id"
                    string="Phase form"
                    options="{'no_create_edit': True, 'no_open': True}"
                    readonly="readonly_timesheet"/>
                <field name="progress" string="Progress %" optional="show"/>
            </field>
            <field name="unit_amount" position="after">
                <field name="end_flag" widget="boolean_toggle"/>
            </field>
        </field>
    </record>

    <record id="hr_timesheet_line_search_inherit_wbs" model="ir.ui.view">
        <field name="name">account.analytic.line.search.hr_timesheet.wbs</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.hr_timesheet_line_search"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='groupby']" position="before">
                <field name="phase_id" string="Phase"/>
            </xpath>
            <xpath expr="//group[@name='groupby']" position="inside">
                <filter string="Phase" name="groupby_phase" domain="[]" context="{'group_by': 'phase_id'}"/>
            </xpath>
        </field>
    </record>

    <record id="view_calendar_account_analytic_line_multi_create_inherit_wbs" model="ir.ui.view">
        <field name="name">account.analytic.line.calendar.multi_create.wbs</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.view_calendar_account_analytic_line_multi_create"/>
        <field name="arch" type="xml">
            <field name="task_id" position="after">
                <field name="phase_id" string="Phase mul" options="{'no_create_edit': True, 'no_open': True}"/>
                <field name="progress" string="Progress %"/>
                <field name="end_flag" widget="boolean_toggle"/>
            </field>
        </field>
    </record>
</odoo>
