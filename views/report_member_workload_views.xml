<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_report_member_workload_calendar" model="ir.ui.view">
        <field name="name">report.member.workload.calendar</field>
        <field name="model">report.member.workload</field>
        <field name="arch" type="xml">
            <calendar date_start="date_start" date_stop="date_stop" 
                string="Member Workload" 
                color="state" 
                mode="month" 
                event_open_popup="true"
                create="0"
                edit="0"
                delete="0"
                quick_create="0">
                <field name="project_id" filters="1"/>
                <field name="state" filters="1"/>
                <field name="user_id" avatar_field="image_128" filters="1"/>
                <field name="task_id"/>
                <field name="phase_id"/>
            </calendar>
        </field>
    </record>

    <record id="view_report_member_workload_list" model="ir.ui.view">
        <field name="name">report.member.workload.list</field>
        <field name="model">report.member.workload</field>
        <field name="arch" type="xml">
            <list string="Member Workload" create="0" edit="0" delete="0" default_order="date_start desc" export_xlsx="0">
                <field name="date_start"/>
                <field name="user_id"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="state" widget="badge" decoration-success="state == 'busy'" decoration-danger="state == 'free'"/>
            </list>
        </field>
    </record>

    <record id="view_report_member_workload_search" model="ir.ui.view">
        <field name="name">report.member.workload.search</field>
        <field name="model">report.member.workload</field>
        <field name="arch" type="xml">
            <search string="Search Workload">
                <field name="user_id"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <filter string="Available" name="free" domain="[('state', '=', 'free')]"/>
                <filter string="Assigned" name="busy" domain="[('state', '=', 'busy')]"/>
                <group>
                    <filter string="Member" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Project" name="group_by_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_report_member_workload" model="ir.actions.server">
        <field name="name">Generate Member Workload</field>
        <field name="model_id" ref="model_report_member_workload"/>
        <field name="state">code</field>
        <field name="code">
            action = model.action_generate_workload()
        </field>
    </record>

    <menuitem id="menu_report_member_workload"
              name="Member Workload"
              parent="project.menu_main_pm"
              action="action_report_member_workload"
              sequence="4"/>
</odoo>
