<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form_wbs" model="ir.ui.view">
        <field name="name">project.task.form.wbs</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_id']" position="after">
                <field name="is_project_manager" invisible="1"/>
            </xpath>
            
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_issues" type="object" class="oe_stat_button" icon="fa-bug">
                    <field name="issue_count" widget="statinfo" string="Issues"/>
                </button>
                <button name="action_view_reviews" type="object" class="oe_stat_button" icon="fa-check-square-o">
                    <field name="review_count" widget="statinfo" string="Reviews"/>
                </button>
            </xpath>

            <!-- Safe ReadOnly Attributes for layout stability -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='priority']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//field[@name='project_id']" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>

            <xpath expr="//sheet//group" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>
            <xpath expr="//notebook" position="attributes">
                <attribute name="readonly">not is_project_manager</attribute>
            </xpath>

            <xpath expr="//page[@name='description_page']" position="after">
                <page string="WBS">
                    <field name="phase_line_ids" context="{'default_project_id': project_id, 'default_task_id': id}" readonly="not is_project_manager">
                        <list editable="bottom">
                            <field name="project_phase_ids" column_invisible="1"/>
                            <field name="phase_id" domain="[('id', 'in', project_phase_ids)]"/>
                            <field name="planned_start" string="Plan Start - End" widget="daterange" options='{"end_date_field": "planned_end", "always_range": "0"}' required="planned_start or planned_end"/>
                            <field name="planned_end" column_invisible="1" required="planned_start"/>
                            <field name="planned_user_ids" string="Plan Members" widget="many2many_avatar_user" domain="[('id', 'in', project_member_ids), ('share', '=', False)]"/>
                            <field name="planned_hours" widget="timesheet_uom" type="measure"/>
                            <field name="actual_start" string="Actual Start - End" widget="daterange" options='{"end_date_field": "actual_end", "always_range": "0"}' required="actual_start or actual_end" optional="hide"/>
                            <field name="actual_end" column_invisible="1" required="actual_start" optional="hide"/>
                            <field name="actual_user_ids" string="Actual Members" widget="many2many_avatar_user" domain="[('id', 'in', project_member_ids), ('share', '=', False)]" optional="hide"/>
                            <field name="actual_hours" widget="timesheet_uom" type="measure" optional="hide"/>
                            <button name="action_view_issues" type="object" icon="fa-bug" title="Issues" invisible="not id"/>
                            <button name="action_view_reviews" type="object" icon="fa-check-square-o" title="Reviews" invisible="not id"/>
                        </list>
                    </field>
                </page>
            </xpath>

            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//label[@for='date_deadline']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[@id='date_deadline_and_recurring_task']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_task_form_readonly" model="ir.ui.view">
        <field name="name">project.task.form.readonly</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project_wbs_extension.view_task_form_wbs"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="edit">0</attribute>
                <attribute name="create">0</attribute>
                <attribute name="delete">0</attribute>
            </xpath>
            <xpath expr="//field[@name='phase_line_ids']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_task_form_timesheets_wbs" model="ir.ui.view">
        <field name="name">project.task.form.timesheets.wbs</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="hr_timesheet.view_task_form2_inherited"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='page_timesheets']//field[@name='timesheet_ids']//list/field[@name='date']" position="after">
                <field name="phase_id" string="Phase" options="{'no_create_edit': True, 'no_open': True}" readonly="readonly_timesheet"/>
            </xpath>
            <xpath expr="//page[@name='page_timesheets']//field[@name='timesheet_ids']/form//field[@name='date']" position="after">
                <field name="phase_id" string="Phase" options="{'no_create_edit': True, 'no_open': True}" readonly="readonly_timesheet"/>
            </xpath>
        </field>
    </record>

    <record id="view_task_tree_readonly" model="ir.ui.view">
        <field name="name">project.task.list.readonly</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="create">0</attribute>
                <attribute name="delete">0</attribute>
                <attribute name="edit">0</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_task_kanban_readonly" model="ir.ui.view">
        <field name="name">project.task.kanban.readonly</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="create">0</attribute>
                <attribute name="delete">0</attribute>
                <attribute name="quick_create">0</attribute>
                <attribute name="group_create">0</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_task_kanban_inherited_wbs" model="ir.ui.view">
        <field name="name">project.task.kanban.inherited.wbs</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_ids']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_view_task_readonly" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">kanban,list,calendar,pivot,graph,form</field>
        <field name="search_view_id" ref="project.view_task_search_form"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'kanban', 'view_id': ref('view_task_kanban_readonly')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_task_tree_readonly')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_task_form_readonly')})]"/>
    </record>
</odoo>
