<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- WBS list -->
    <record id="view_project_wbs_list" model="ir.ui.view">
        <field name="name">project.wbs.list</field>
        <field name="model">project.task.phase</field>
        <field name="arch" type="xml">
            <list duplicate="false" class="wbs-list" expand="1" default_order="planned_start asc">
                <field name="task_id"/>
                <field name="phase_id"/>
                <field name="planned_start" string="Plan Start - End" widget="daterange" options='{"end_date_field": "planned_end", "always_range": "0"}' required="planned_start or planned_end"/>
                <field name="planned_end" column_invisible="1" required="planned_start"/>
                <field name="planned_user_ids" string="Plan Member" widget="many2many_avatar_user" domain="[('share', '=', False)]"/>
                <field name="planned_hours" widget="timesheet_uom" type="measure"/>
                <field name="actual_start" string="Actual Start - End" widget="daterange" options='{"end_date_field": "actual_end", "always_range": "0"}' required="actual_start or actual_end"/>
                <field name="actual_end" column_invisible="1" required="actual_start"/>
                <field name="actual_user_ids" string="Actual Member" widget="many2many_avatar_user" domain="[('share', '=', False)]"/>
                <field name="actual_hours" widget="timesheet_uom" type="measure"/>
                <field name="issue_count" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- WBS search -->
    <record id="view_project_wbs_search" model="ir.ui.view">
        <field name="name">project.wbs.search</field>
        <field name="model">project.task.phase</field>
        <field name="arch" type="xml">
            <search string="Search WBS">
                <filter string="PS" name="filter_phase_ps" domain="[('phase_id.display_name', '=', 'PS')]"/>
                <filter string="PG" name="filter_phase_ps" domain="[('phase_id.display_name', '=', 'PG')]"/>
                <filter string="PG Review" name="filter_phase_ps" domain="[('phase_id.display_name', '=', 'PGR')]"/>
                <filter string="PT" name="filter_phase_ps" domain="[('phase_id.display_name', '=', 'PT')]"/>
                <filter string="PT Review" name="filter_phase_ps" domain="[('phase_id.display_name', '=', 'PTR')]"/>
                <filter string="IT" name="filter_phase_ps" domain="[('phase_id.display_name', '=', 'IT')]"/>
                <filter string="IT Review" name="filter_phase_ps" domain="[('phase_id.display_name', '=', 'ITR')]"/>
                <group>
                    <filter string="Project" name="group_by_project" context="{'group_by':'project_id'}"/>
                    <filter string="Phase" name="group_by_phase" context="{'group_by':'phase_id'}"/>
                    <filter string="Planned" name="group_by_planned" context="{'group_by':'planned_start'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- WBS form -->
    <record id="view_project_wbs_form" model="ir.ui.view">
        <field name="name">project.wbs.form</field>
        <field name="model">project.task.phase</field>
        <field name="arch" type="xml">
            <form string="Wbs">
                <sheet>
                    <div class="oe_title">
                        <h1 class="d-flex flex-row">
                            <field name="project_id" class="o_text_overflow"/>
                        </h1>
                    </div>
                    <group col="3">
                        <group col="2" colspan="2">
                            <field name="task_id" colspan="2"/>
                        </group>
                        <group>
                            <field name="phase_id"/>
                        </group>
                    </group>
                    <!-- tabs -->
                    <notebook>
                        <page string="Infomation">
                            <group>
                                <group>
                                    <field name="planned_start" string="Plan Start - End" widget="daterange" options='{"end_date_field": "planned_end", "always_range": "1"}' required="planned_start or planned_end"/>
                                    <field name="planned_end" invisible="1" required="planned_start"/>
                                    <field name="planned_user_ids" string="Plan Members" widget="many2many_avatar_user" domain="[('share', '=', False)]"/>
                                    <field name="planned_hours" widget="timesheet_uom" type="measure"/>
                                </group>
                                <group>
                                    <field name="actual_start" string="Actual Start - End" widget="daterange" options='{"end_date_field": "actual_end", "always_range": "1"}' required="actual_start or actual_end"/>
                                    <field name="actual_end" invisible="1" required="actual_start"/>
                                    <field name="actual_user_ids" string="Actual Members" widget="many2many_avatar_user" domain="[('share', '=', False)]"/>
                                    <field name="actual_hours" widget="timesheet_uom" type="measure"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter block -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- WBS calendar -->
    <record id="view_project_wbs_calendar" model="ir.ui.view">
        <field name="name">project.wbs.calendar</field>
        <field name="model">project.task.phase</field>
        <field eval="2" name="priority"/>
        <field name="arch" type="xml">
            <calendar
                date_start="planned_start"
                date_stop="planned_end"
                string="WBS Calendar"
                mode="month"
                scales="month,year"
                event_open_popup="true"
                js_class="project_task_calendar"
                quick_create="0"
                color="project_id">
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="phase_id"/>
                <field name="planned_user_ids" filters="1"/>
                <field name="planned_hours"/>
            </calendar>
        </field>
    </record>

    <!-- WBS action-->
    <record id="action_project_wbs" model="ir.actions.act_window">
        <field name="name">WBS</field>
        <field name="res_model">project.task.phase</field>
        <field name="view_id" ref="view_project_wbs_list"/>
        <field name="view_mode">list,calendar,form</field>
        <field name="search_view_id" ref="view_project_wbs_search"/>
        <field name="domain">[('project_id.active', '=', True)]</field>
        <field name="context">{'group_by': ['project_id', 'phase_id'], 'search_default_group_by_project': 1, 'search_default_group_by_phase': 1}</field>
        <field name="target">current</field>
        <field name="path">wbs</field>
    </record>

    <!-- Add menu WBS to project -->
    <menuitem id="menu_project_wbs" name="WBS"
            parent="project.menu_main_pm"
            action="action_project_wbs"
            sequence="3"/>
</odoo>
